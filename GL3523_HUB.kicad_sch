	(text "Active low, so pull up assuming no \novercurrent will occur.\n\nPWREN=NC because power is on \nfor each port by default. I am not using hardware loadswitching"
		(exclude_from_sim no)
		(at 32.258 101.854 0)
		(effects
			(font
				(size 1.27 1.27)
			)
		)
		(uuid "80c38e32-3c7c-49b0-9b4d-d1a8c1d706ba")
	)
	(text "AMBER_P2 pulled low as a strap pin\nso that PWREN pins can be NC"
		(exclude_from_sim no)
		(at 32.004 113.03 0)
		(effects
			(font
				(size 1.27 1.27)
			)
		)
		(uuid "8c646900-5c28-48d8-8dc9-b2be41b226c7")
	)
	(text "COMMENT on V33:\nThis can be used as a power IN or OUT. \nIt downregulates the 5V input to 3v3 internally.\nBut you can also supply it with 3v3.\nIn this case we will use the 3v3 from the M.2 key\nIn this case, V5 is not being used to generate the 3v3 voltage.\nV5 must be connected to 3v3 instead.\nHowever VBUS still requires the 5V supply."
		(exclude_from_sim no)
		(at 153.162 134.62 0)
		(effects
			(font
				(size 1.27 1.27)
			)
		)
		(uuid "8fef27da-437b-4348-a215-89508cb3eca8")
	)
